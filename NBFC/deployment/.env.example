# Copy to deployment/.env on your VPS:
#   cp .env.example .env && nano .env
#
# VPS: 69.62.74.175
# Frontend: https://nbfc.codingera.in
# Backend:  https://api.nbfc.codingera.in

# -----------------------------------------------------------------------------
# Domains (used for frontend build + CORS)
# -----------------------------------------------------------------------------
FRONTEND_ORIGIN=https://nbfc.codingera.in
API_BASE_URL=https://api.nbfc.codingera.in/api/v1

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=patsanstha
POSTGRES_PORT=15432

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PORT=16379

# -----------------------------------------------------------------------------
# Host ports (127.0.0.1 only — nginx on host proxies these)
# Change if any port is already in use by another project on the VPS.
# -----------------------------------------------------------------------------
API_PORT=15280
GATEWAY_PORT=15000
SHELL_PORT=15200

# -----------------------------------------------------------------------------
# API runtime
# -----------------------------------------------------------------------------
ASPNETCORE_ENVIRONMENT=Production
STARTUP_AUTO_MIGRATE=true
STARTUP_SEED_IDENTITY=true

# -----------------------------------------------------------------------------
# Security — generate strong random strings (min 32 characters each)
#   openssl rand -base64 32
# -----------------------------------------------------------------------------
JWT__SigningKey=replace-with-a-random-256-bit-secret-key-min-32-chars
PiiEncryption__Key=replace-with-another-random-256-bit-secret-key

JWT__Issuer=Patsanstha
JWT__Audience=Patsanstha.Api
JWT__AccessTokenMinutes=15
JWT__RefreshTokenDays=7

# -----------------------------------------------------------------------------
# Default admin user (created on first seed only)
# -----------------------------------------------------------------------------
IdentitySeed__AdminEmail=admin@codingera.in
IdentitySeed__AdminPassword=ChangeMe@StrongPassword123
IdentitySeed__AdminFullName=System Administrator
IdentitySeed__DefaultTenantId=00000000-0000-0000-0000-000000000001

# -----------------------------------------------------------------------------
# Gateway → API (internal Docker network; leave as-is)
# -----------------------------------------------------------------------------
GATEWAY_API_ADDRESS=http://api:8080/
