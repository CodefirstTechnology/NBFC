# Copy this file to `.env` on your VPS and fill in real values.
#   cp .env.example .env
#
# Never commit `.env` — it contains secrets.

# -----------------------------------------------------------------------------
# PostgreSQL (docker-compose postgres service)
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=patsanstha

# Bind Postgres/Redis to localhost only on VPS (recommended).
# Set to 0.0.0.0 only if you need remote DB access (not recommended).
POSTGRES_BIND=127.0.0.1
REDIS_BIND=127.0.0.1

# -----------------------------------------------------------------------------
# API runtime
# -----------------------------------------------------------------------------
ASPNETCORE_ENVIRONMENT=Production

# Run EF migrations on API startup (recommended for first VPS deploy).
STARTUP_AUTO_MIGRATE=true

# Seed roles, permissions, and admin user on startup (safe to re-run; idempotent).
STARTUP_SEED_IDENTITY=true

# -----------------------------------------------------------------------------
# Security — generate strong random strings (min 32 characters each)
# -----------------------------------------------------------------------------
JWT__SigningKey=replace-with-a-random-256-bit-secret-key-min-32-chars
PiiEncryption__Key=replace-with-another-random-256-bit-secret-key

JWT__Issuer=Patsanstha
JWT__Audience=Patsanstha.Api
JWT__AccessTokenMinutes=15
JWT__RefreshTokenDays=7

# -----------------------------------------------------------------------------
# Default admin user (created on first seed only)
# -----------------------------------------------------------------------------
IdentitySeed__AdminEmail=admin@yourdomain.com
IdentitySeed__AdminPassword=ChangeMe@StrongPassword123
IdentitySeed__AdminFullName=System Administrator
IdentitySeed__DefaultTenantId=00000000-0000-0000-0000-000000000001

# -----------------------------------------------------------------------------
# Published ports (host → container)
# -----------------------------------------------------------------------------
API_PORT=5080
GATEWAY_PORT=5000
SHELL_PORT=4200

# -----------------------------------------------------------------------------
# Gateway → API (internal Docker network; usually leave as-is)
# -----------------------------------------------------------------------------
GATEWAY_API_ADDRESS=http://api:8080/
