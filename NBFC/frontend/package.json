{
  "name": "@patsanstha/source",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "start": "nx serve shell",
    "start:member": "nx serve mfe-member",
    "start:deposit": "nx serve mfe-deposit",
    "start:loan": "nx serve mfe-loan",
    "start:collection": "nx serve mfe-collection",
    "start:recovery": "nx serve mfe-recovery",
    "start:accounting": "nx serve mfe-accounting",
    "start:reports": "nx serve mfe-reports",
    "start:admin": "nx serve mfe-admin",
    "start:all": "nx run-many -t serve -p shell mfe-member mfe-deposit mfe-loan mfe-collection mfe-recovery mfe-accounting mfe-reports mfe-admin --parallel=4",
    "build": "nx build shell",
    "test": "nx run-many -t test",
    "lint": "nx run-many -t lint",
    "docker:build": "docker compose build",
    "docker:build:parallel": "docker compose build --parallel",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "@angular/animations": "~19.2.0",
