    "@schematics/angular": "~19.2.0",
    "@softarc/native-federation-node": "^2.0.10",
    "@types/node": "^20.0.0",
    "@typescript-eslint/utils": "^8.19.0",
    "autoprefixer": "^10.4.20",
    "es-module-shims": "^2.8.1",
    "eslint": "^9.16.0",
