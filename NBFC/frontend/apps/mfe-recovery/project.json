{
  "name": "mfe-recovery",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/mfe-recovery/src",
  "prefix": "pats",
  "tags": ["scope:recovery", "type:mfe"],
  "targets": {
    "build": {
      "executor": "@angular-architects/native-federation:build",
      "configurations": {
        "production": { "target": "mfe-recovery:esbuild:production" },
        "development": { "target": "mfe-recovery:esbuild:development" }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "executor": "@angular-architects/native-federation:build",
      "options": {
        "target": "mfe-recovery:serve-original:development",
        "rebuildDelay": 0,
        "dev": true
      }
    },
    "serve-original": {
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "mfe-recovery:esbuild:production"
        },
        "development": {
          "buildTarget": "mfe-recovery:esbuild:development",
          "port": 4205
        }
      },
      "defaultConfiguration": "development"
    },
    "esbuild": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/mfe-recovery",
        "index": "apps/mfe-recovery/src/index.html",
        "browser": "apps/mfe-recovery/src/main.ts",
        "polyfills": ["zone.js", "es-module-shims"],
        "tsConfig": "apps/mfe-recovery/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [{ "glob": "**/*", "input": "apps/mfe-recovery/public" }],
        "styles": ["apps/mfe-recovery/src/styles.scss"],
        "scripts": []
      },
      "configurations": {
        "production": { "outputHashing": "all" },
        "development": { "optimization": false, "extractLicenses": false, "sourceMap": true }
      },
      "defaultConfiguration": "production"
    },
    "lint": { "executor": "@nx/eslint:lint" }
  }
}
